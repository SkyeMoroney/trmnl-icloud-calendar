{% render 'shared' %}
{% if has_data %}
<div class="ical-agenda">
  <div class="ical-agenda-title">{{ period_label }} — Upcoming</div>
  <div class="ical-agenda-list">
    {% for ev in next_events limit: 6 %}
      <div class="ical-agenda-row">
        <div class="ical-agenda-when">{{ ev.label }} · {{ ev.time }}</div>
        <div class="ical-agenda-what {{ ev.shade }}">{{ ev.title }}</div>
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .ical-agenda { display: flex; flex-direction: column; height: 100%; padding: 6px 10px; }
  .ical-agenda-title { font-size: 18px; font-weight: 700; margin-bottom: 6px; }
  .ical-agenda-list { flex: 1; display: flex; flex-direction: column; gap: 4px; }
  .ical-agenda-row { display: flex; justify-content: space-between; gap: 10px; font-size: 13px; border-bottom: 1px dotted; padding-bottom: 3px; }
  .ical-agenda-when { flex-shrink: 0; font-weight: 600; }
  .ical-agenda-what { font-weight: 600; text-align: right; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
</style>
{% endif %}
