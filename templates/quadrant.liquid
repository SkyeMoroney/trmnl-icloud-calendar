{% if has_data == false %}
  <div class="ical-error">
    <div class="ical-error-title">iCloud Calendar</div>
    <div class="ical-error-message">{{ error | default: "No data yet." }}</div>
  </div>
  <style>
    .ical-error { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; text-align: center; padding: 16px; }
    .ical-error-title { font-size: 20px; font-weight: 700; margin-bottom: 8px; }
    .ical-error-message { font-size: 13px; max-width: 90%; }
  </style>
{% endif %}
{% if has_data %}
<div class="ical-agenda">
  <div class="ical-agenda-list">
    {% for ev in next_events limit: 3 %}
      <div class="ical-agenda-row">
        <div class="ical-agenda-when">{{ ev.label }} · {{ ev.time }}</div>
        <div class="ical-agenda-what {{ ev.shade }}">{{ ev.title }}</div>
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .ical-agenda { display: flex; flex-direction: column; height: 100%; padding: 4px 6px; justify-content: center; }
  .ical-agenda-list { display: flex; flex-direction: column; gap: 4px; }
  .ical-agenda-row { font-size: 11px; border-bottom: 1px dotted; padding-bottom: 2px; }
  .ical-agenda-when { font-weight: 600; }
  .ical-agenda-what { font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
</style>
{% endif %}
