{% render 'shared' %}
{% if has_data %}
<div class="ical-wrap">
  <div class="ical-header">
    <div class="ical-title">{{ period_label }}</div>
    <div class="ical-legend">
      {% for cal in calendars %}<span class="ical-legend-item {{ cal.shade }}">[{{ cal.index }}] {{ cal.name }}</span>{% endfor %}
    </div>
  </div>

  {% if multiday_events.size > 0 %}
    <div class="ical-banner">
      {% for bar in multiday_events limit: 4 %}
        <div class="ical-bar {{ bar.shade }}" style="grid-column: {{ bar.col }} / span {{ bar.span }};">{{ bar.title }}</div>
      {% endfor %}
    </div>
  {% endif %}

  <div class="ical-weekdays">
    {% for w in weekday_labels %}<div>{{ w }}</div>{% endfor %}
  </div>

  <div class="ical-week-grid">
    {% for day in week_days %}
      <div class="ical-day-cell{% if day.is_today %} ical-day-cell--today bg--black text--white{% endif %}">
        <div class="ical-daynum">{{ day.day }}</div>
        {% for ev in day.events limit: 6 %}
          <div class="ical-event{% unless day.is_today %} {{ ev.shade }}{% endunless %}">{{ ev.time }} {{ ev.title }}</div>
        {% endfor %}
        {% if day.events.size > 6 %}
          <div class="ical-more">+{{ day.events.size | minus: 6 }} more</div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .ical-wrap { display: flex; flex-direction: column; height: 100%; font-family: inherit; }
  .ical-header { display: flex; justify-content: space-between; align-items: baseline; padding: 4px 8px; }
  .ical-title { font-size: 26px; font-weight: 700; }
  .ical-legend { font-size: 12px; }
  .ical-legend-item { margin-left: 10px; font-weight: 600; }

  .ical-banner { display: grid; grid-template-columns: repeat(7, 1fr); grid-auto-rows: 16px; gap: 2px; margin: 0 8px 4px; }
  .ical-bar { border: 1px solid; font-size: 10px; font-weight: 600; padding: 1px 5px; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }

  .ical-weekdays { display: grid; grid-template-columns: repeat(7, 1fr); font-size: 12px; font-weight: 700; text-align: center; border-bottom: 1px solid; padding-bottom: 3px; margin: 0 8px; }
  .ical-week-grid { flex: 1; display: grid; grid-template-columns: repeat(7, 1fr); gap: 1px; margin: 4px 8px 8px; }
  .ical-day-cell { border: 1px solid; padding: 3px 4px; overflow: hidden; font-size: 11px; }
  .ical-daynum { font-weight: 700; font-size: 15px; margin-bottom: 2px; }
  .ical-event { font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ical-more { font-style: italic; }
</style>
{% endif %}
